---
layout: base.html
title: الأرشيف
seo_title: الأرشيف | المدونة الشخصية لمحمد الجندي
seo_description: جميع المقالات والتدوينات في مدونة محمد الجندي مرتبة من الأحدث إلى الأقدم.
permalink: /archive/
---

<div class="container">

  {#
    ─────────────────────────────────────────────────────────────
    ARCHIVE PAGE
    - All posts, newest first.
    - Horizontal list cards (same pattern as "المزيد من المقالات").
    - No filters — plain, complete list.
    ─────────────────────────────────────────────────────────────
  #}

  {%- set allPosts = collections.posts | reverse %}

  {# Page heading #}
  <div class="archive-header">
    <p class="section-label">جميع المقالات</p>
    <p class="archive-count">{{ allPosts | length }} مقالة</p>
  </div>

  {%- if allPosts | length > 0 %}
  <div class="archive-list">

    {%- for post in allPosts %}
    <article class="archive-card">

      {# Thumbnail — same placeholder pattern as the rest of the site #}
      <div class="archive-card-thumb">
        {%- if post.data.thumbnail %}
          <img src="{{ post.data.thumbnail }}" alt="{{ post.data.title }}" loading="lazy" />
        {%- else %}
          <div class="archive-card-thumb-default" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
              <path d="M3 9h18M9 21V9"/>
            </svg>
          </div>
        {%- endif %}
      </div>

      {# Card body — title, meta, description #}
      <div class="archive-card-body">

        <div class="archive-card-meta">
          <span class="archive-card-date">{{ post.date | date }}</span>
          {%- if post.data.category %}
            <span class="archive-card-cat">{{ post.data.category | trim }}</span>
          {%- endif %}
          {%- if post.data.series %}
            <span class="archive-card-series">{{ post.data.series }}</span>
          {%- endif %}
        </div>

        <h2 class="archive-card-title">
          <a href="{{ post.url }}">{{ post.data.title }}</a>
        </h2>

        {%- if post.data.description %}
          <p class="archive-card-desc">{{ post.data.description }}</p>
        {%- endif %}

      </div>

    </article>
    {%- endfor %}

  </div>
  {%- else %}
  <p class="archive-empty">لا توجد مقالات بعد.</p>
  {%- endif %}

</div>
